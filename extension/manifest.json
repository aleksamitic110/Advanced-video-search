{
  "manifest_version": 3,
  "name": "YT Video Search Extension",
  "description": "Multimodal search over selected YouTube videos using local BM25 and vector indexes.",
  "version": "0.1.0",
  "action": {
    "default_title": "YT Search",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://www.youtube.com/*"
  ]
}
